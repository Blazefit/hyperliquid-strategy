# Hyperliquid credentials
# Generate a wallet on https://app.hyperliquid.xyz
# Export the private key from your wallet
HL_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
HL_WALLET_ADDRESS=0xYOUR_WALLET_ADDRESS_HERE

# Set to 1 to enable real trading (default: paper mode)
HYPERLIQUID_LIVE=0

# Dashboard settings
HL_DASH_PORT=8181

# Dashboard auth (required for remote/Tailscale access)
# Without these, dashboard has no login -- fine for localhost only
HL_DASH_USER=admin
HL_DASH_PASS=CHANGE_ME_TO_SOMETHING_SECURE

# AI Consensus (required for daily risk overlay)
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
MINIMAX_API_KEY=YOUR_MINIMAX_KEY_HERE
